{
  "camera": {
    "index": 0,
    "target_fps": 60,
    "fallback_fps": 30,
    "width": 1280,
    "height": 720
  },
  "tracker": {
    "max_num_hands": 2,
    "min_detection_confidence": 0.5,
    "min_presence_confidence": 0.5,
    "min_tracking_confidence": 0.5,
    "mirrored": false
  },
  "calibration": {
    "matrix": null,
    "calibrated_resolution": null,
    "calibrated_at": null,
    "averaging_frames": 60,
    "use_center_validation": true
  },
  "gestures": {
    "activation_zone_threshold": 0.15,
    "tap_speed_threshold": 1.2,
    "tap_decel_ratio": 0.4,
    "tap_time_ms": 250,
    "tap_cooldown_ms": 300,
    "drag_decision_ms": 150,
    "drag_distance_threshold": 0.08,
    "scroll_speed_threshold": 0.4,
    "scroll_multiplier": 1.0
  },
  "cursor": {
    "smoothing_alpha": 0.4
  },
  "keybindings": {
    "swipe_left": {
      "macos": ["cmd", "["],
      "windows": ["alt", "left"]
    },
    "swipe_right": {
      "macos": ["cmd", "]"],
      "windows": ["alt", "right"]
    },
    "swipe_up": {
      "macos": ["ctrl", "up"],
      "windows": ["cmd", "tab"]
    },
    "swipe_down": {
      "macos": ["ctrl", "down"],
      "windows": ["cmd", "d"]
    },
    "toggle_pause": {
      "macos": ["ctrl", "shift", "g"],
      "windows": ["ctrl", "shift", "g"]
    }
  },
  "app": {
    "debug_mode": false,
    "log_level": "INFO",
    "start_paused": false,
    "latency_warning_ms": 80
  }
}
